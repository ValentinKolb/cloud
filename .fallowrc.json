{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "publicPackages": ["@valentinkolb/cloud"],
  "entry": [
    "packages/cloud/src/index.ts",
    "packages/cloud/src/services/index.ts",
    "packages/cloud/src/services/*/index.ts",
    "packages/cloud/src/server/index.ts",
    "packages/cloud/src/server/services/index.ts",
    "packages/cloud/src/server/services/freeipa/index.ts",
    "packages/cloud/src/server/middleware/index.ts",
    "packages/cloud/src/ui/index.ts",
    "packages/cloud/src/ssr/index.ts",
    "packages/cloud/src/ssr/islands/index.ts",
    "packages/cloud/src/contracts/index.ts",
    "packages/cloud/src/shared/index.ts",
    "packages/cloud/src/config/index.ts",
    "packages/cloud/src/clients/core.ts"
  ],
  "dynamicallyLoaded": [
    "styles.css",
    "packages/*/src/styles/app.css",
    "packages/*/scripts/build-extras.ts",
    "packages/*/scripts/dev-extras.ts",
    "packages/cloud/scripts/preload.ts"
  ],
  "ignoreDependencies": [
    "lean-qr",
    "@tailwindcss/typography",
    "@babel/preset-typescript",
    "babel-preset-solid",
    "notebooks-script-intelligence"
  ]
}

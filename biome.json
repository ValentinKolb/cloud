{
  "$schema": "https://biomejs.dev/schemas/2.4.2/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!**/node_modules/**", "!**/dist/**", "!**/build/**", "!**/_ssr/**"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 140
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": {
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn"
      },
      "suspicious": {
        "noAssignInExpressions": "error",
        "noDebugger": "error",
        "noImplicitAnyLet": "error"
      },
      "a11y": {
        "noLabelWithoutControl": "error",
        "noStaticElementInteractions": "error",
        "useAnchorContent": "error",
        "useAriaPropsSupportedByRole": "error",
        "useKeyWithClickEvents": "error",
        "useValidAriaRole": "error"
      },
      "style": {
        "useImportType": "warn",
        "useBlockStatements": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}

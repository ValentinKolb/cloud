{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@valentinkolb/cloud-core": ["../core/src/index.ts"],
      "@valentinkolb/cloud-core/config": ["../core/src/config/index.ts"],
      "@valentinkolb/cloud-core/config/*": ["../core/src/config/*"],
      "@valentinkolb/cloud-core/services/*": ["../core/src/services/*"],
      "@valentinkolb/cloud-contracts": ["../contracts/src/index.ts"],
      "@valentinkolb/cloud-contracts/*": ["../contracts/src/*"],
      "@valentinkolb/cloud-lib/ui": ["./src/ui/index.ts"],
      "@valentinkolb/cloud-lib/browser": ["./src/browser/index.ts"],
      "@valentinkolb/cloud-lib/shared": ["./src/shared/index.ts"],
      "@valentinkolb/cloud-lib/islands": ["./src/islands/index.ts"],
      "@valentinkolb/cloud-lib/server": ["./src/server/index.ts"],
      "@valentinkolb/cloud-lib/server/api": ["./src/server/api/index.ts"],
      "@valentinkolb/cloud-lib/server/middleware": ["./src/server/middleware/index.ts"],
      "@valentinkolb/cloud-lib/server/middleware/*": ["./src/server/middleware/*"],
      "@valentinkolb/cloud-lib/server/services": ["./src/server/services/index.ts"],
      "@valentinkolb/cloud-lib/styles/*": ["./src/styles/*"],
      "@valentinkolb/cloud-lib/*": ["./src/*"]
    }
  }
}

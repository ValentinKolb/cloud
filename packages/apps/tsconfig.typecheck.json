{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*", "../lib/src/*", "../core/src/*", "../contracts/src/*"],
      "@valentinkolb/cloud/core": ["../core/src/index.ts"],
      "@valentinkolb/cloud/core/ssr": ["../core/src/ssr/index.ts"],
      "@valentinkolb/cloud/core/config": ["../core/src/config/index.ts"],
      "@valentinkolb/cloud/core/settings": ["../core/src/settings.ts"],
      "@valentinkolb/cloud/core/services": ["../core/src/services/index.ts"],
      "@valentinkolb/cloud/lib/server": ["../lib/src/server/index.ts"],
      "@valentinkolb/cloud/lib/ui": ["../lib/src/ui/index.ts"],
      "@valentinkolb/cloud/lib/islands": ["../lib/src/islands/index.ts"],
      "@valentinkolb/cloud/lib/browser": ["../lib/src/browser/index.ts"],
      "@valentinkolb/cloud/lib/shared": ["../lib/src/shared/index.ts"],
      "@valentinkolb/cloud/lib/styles/global.css": ["../lib/src/styles/global.css"],
      "@valentinkolb/cloud/contracts/app": ["../contracts/src/app.ts"],
      "@valentinkolb/cloud/contracts/shared": ["../contracts/src/shared.ts"],
      "@valentinkolb/cloud/apps": ["./src/index.ts"],

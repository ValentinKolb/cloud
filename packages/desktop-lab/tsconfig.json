{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.AsyncIterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@valentinkolb/cloud": ["../cloud/src/index.ts"],
      "@valentinkolb/cloud/ui": ["../cloud/src/ui/index.ts"],
      "@valentinkolb/cloud/desktop": ["../cloud/src/desktop/index.ts"],
      "@valentinkolb/cloud/desktop/solid": ["../cloud/src/desktop/solid.tsx"],
      "@valentinkolb/cloud/browser": ["../cloud/src/server/api-client.ts"],
      "@valentinkolb/cloud/shared": ["../cloud/src/shared/index.ts"],
      "@valentinkolb/cloud/contracts": ["../cloud/src/contracts/index.ts"],
      "@valentinkolb/cloud/contracts/*": ["../cloud/src/contracts/*"]
    },
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": ["./src/**/*.ts", "./src/**/*.tsx", "../cloud/src/types/**/*.d.ts"],
  "exclude": ["./dist", "./node_modules"]
}

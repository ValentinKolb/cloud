{
  "name": "@valentinkolb/cloud-desktop-lab",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "build": "bun run src/build.ts",
    "dev": "bun run src/dev-server.ts",
    "native:build": "electrobun build",
    "native:dev": "electrobun dev",
    "native:watch": "electrobun dev --watch",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.typecheck.json --noEmit --pretty false 2>&1 | grep -v node_modules | (! grep -q 'error TS')"
  },
  "dependencies": {
    "@valentinkolb/cloud": "workspace:*",
    "@valentinkolb/stdlib": "0.9.1",
    "solid-js": "^1.9.10"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@types/bun": "1.3.9",
    "babel-preset-solid": "^1.9.12",
    "bun-plugin-tailwind": "^0.1.2",
    "electrobun": "^1.18.1",
    "typescript": "^5.9.3"
  },
  "license": "AGPL-3.0-or-later"
}

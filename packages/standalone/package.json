{
  "name": "@valentinkolb/cloud-standalone",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "dev": "NODE_ENV=development bun --env-file=../../.env --watch --no-clear-screen --preload=./scripts/preload.ts run src/app.tsx",
    "dev:skip-setup": "NODE_ENV=development SKIP_SETUP=true bun --env-file=../../.env --watch --no-clear-screen --preload=./scripts/preload.ts run src/app.tsx",
    "build": "bun run scripts/build.ts app.tsx",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.typecheck.json --noEmit --pretty false",
    "serve": "NODE_ENV=production bun run dist/app.js",
    "migrate": "bun --env-file=../../.env run src/migrate.ts"
  },
  "dependencies": {
    "@valentinkolb/cloud-core": "workspace:*",
    "@valentinkolb/cloud-apps": "workspace:*",
    "@valentinkolb/cloud-lib": "workspace:*",
    "bun-plugin-tailwind": "^0.1.2",
    "seroval": "^1.3.2",
    "seroval-plugins": "^1.3.3",
    "solid-js": "^1.9.10"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": "./src/index.ts"
  }
}

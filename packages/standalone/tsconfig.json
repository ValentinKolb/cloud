{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.AsyncIterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*", "../apps/src/*", "../core/src/*", "../lib/src/*", "../contracts/src/*"],
      "@valentinkolb/cloud/core": ["../core/src/index.ts"],
      "@valentinkolb/cloud/core/ssr": ["../core/src/ssr/index.ts"],
      "@valentinkolb/cloud/core/config": ["../core/src/config/index.ts"],
      "@valentinkolb/cloud/core/settings": ["../core/src/settings.ts"],
      "@valentinkolb/cloud/core/services": ["../core/src/services/index.ts"],
      "@valentinkolb/cloud/lib/server": ["../lib/src/server/index.ts"],
      "@valentinkolb/cloud/lib/ui": ["../lib/src/ui/index.ts"],
      "@valentinkolb/cloud/lib/islands": ["../lib/src/islands/index.ts"],
      "@valentinkolb/cloud/lib/browser": ["../lib/src/browser/index.ts"],
      "@valentinkolb/cloud/lib/shared": ["../lib/src/shared/index.ts"],
      "@valentinkolb/cloud/lib/styles/global.css": ["../lib/src/styles/global.css"],
      "@valentinkolb/cloud/contracts/app": ["../contracts/src/app.ts"],
      "@valentinkolb/cloud/contracts/shared": ["../contracts/src/shared.ts"],
      "@valentinkolb/cloud/apps": ["../apps/src/index.ts"],
      "@valentinkolb/cloud/apps/*": ["../apps/src/*/index.ts"],
      "@valentinkolb/cloud/apps/*/client": ["../apps/src/*/client.ts"],
      "@valentinkolb/cloud-core": ["../core/src/index.ts"],
      "@valentinkolb/cloud-core/ssr": ["../core/src/ssr/index.ts"],
      "@valentinkolb/cloud-core/config": ["../core/src/config/index.ts"],
      "@valentinkolb/cloud-core/config/*": ["../core/src/config/*"],
      "@valentinkolb/cloud-core/services/*": ["../core/src/services/*"],
      "@valentinkolb/cloud-apps": ["../apps/src/index.ts"],
      "@valentinkolb/cloud-apps/*": ["../apps/src/*"],
      "@valentinkolb/cloud-lib/server": ["../lib/src/server/index.ts"],
      "@valentinkolb/cloud-lib/server/middleware": ["../lib/src/server/middleware/index.ts"],
      "@valentinkolb/cloud-lib/server/middleware/*": ["../lib/src/server/middleware/*"],
      "@valentinkolb/cloud-lib/server/services": ["../lib/src/server/services/index.ts"],
      "@valentinkolb/cloud-lib/server/api": ["../lib/src/server/api/index.ts"],
      "@valentinkolb/cloud-contracts": ["../contracts/src/index.ts"],
      "@valentinkolb/cloud-contracts/*": ["../contracts/src/*"],
      "@valentinkolb/cloud-lib/ui": ["../lib/src/ui/index.ts"],
      "@valentinkolb/cloud-lib/islands": ["../lib/src/islands/index.ts"],
      "@valentinkolb/cloud-lib/browser": ["../lib/src/browser/index.ts"],
      "@valentinkolb/cloud-lib/shared": ["../lib/src/shared/index.ts"],
      "@valentinkolb/cloud-lib/styles/*": ["../lib/src/styles/*"],
      "@config": ["../core/src/config/index.ts"]
    },
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": [
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./scripts/**/*.ts",
    "../core/src/env.d.ts",
    "../core/src/types/app-check/**/*.d.ts",
    "../core/src/config/**/*.ts"
  ],
  "exclude": ["./dist", "./node_modules"]
}

# Companion file to compose.prod.yml. Copy to .env and fill in.

# Postgres credentials. Used by every app's DATABASE_URL and by the
# postgres service you define alongside this compose file.
POSTGRES_USER=cloud
POSTGRES_PASSWORD=change-me
POSTGRES_DB=cloud

# Session signing key — generate with: openssl rand -base64 48
APP_SECRET=change-me

# Public hostname routed by Traefik to the gateway.
CLOUD_HOST=cloud.example.com

{
  "name": "@valentinkolb/cloud",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/lib",
    "packages/contracts",
    "packages/apps",
    "packages/standalone"
  ],
  "exports": {
    ".": "./packages/core/src/index.ts",
    "./core": "./packages/core/src/index.ts",
    "./core/ssr": "./packages/core/src/ssr/index.ts",
    "./core/config": "./packages/core/src/config/index.ts",
    "./core/settings": "./packages/core/src/settings.ts",
    "./core/services": "./packages/core/src/services/index.ts",
    "./lib/server": "./packages/lib/src/server/index.ts",
    "./lib/ui": "./packages/lib/src/ui/index.ts",
    "./lib/browser": "./packages/lib/src/browser/index.ts",
    "./lib/shared": "./packages/lib/src/shared/index.ts",
    "./lib/islands": "./packages/lib/src/islands/index.ts",
    "./lib/styles/global.css": "./packages/lib/src/styles/global.css",
    "./contracts/app": "./packages/contracts/src/app.ts",
    "./contracts/shared": "./packages/contracts/src/shared.ts",
    "./apps": "./packages/apps/src/index.ts",
    "./apps/*": "./packages/apps/src/*/index.ts",
    "./apps/*/client": "./packages/apps/src/*/client.ts",
    "./standalone": "./packages/standalone/src/index.ts"
  },
  "scripts": {
    "dev": "bun run --cwd packages/standalone dev",
    "dev:skip-setup": "bun run --cwd packages/standalone dev:skip-setup",
    "build": "bun run --filter @valentinkolb/cloud-standalone build",
    "format": "bun run scripts/run-biome.ts format",
    "format:check": "bun run scripts/run-biome.ts format:check",
    "lint": "bun run scripts/run-biome.ts lint",
    "lint:fix": "bun run scripts/run-biome.ts lint:fix",
    "check:biome": "bun run scripts/run-biome.ts check:biome",
    "skills:install": "./scripts/symlink-skills.sh",
    "typecheck": "bun run check:skills && bun run check:boundaries && bun run check:cycles && bun run check:service-api-contracts && bun run check:biome && bun run scripts/run-package-typechecks.ts",
    "check": "bun run typecheck",
    "serve": "bun run --filter @valentinkolb/cloud-standalone serve",
    "migrate": "bun run --filter @valentinkolb/cloud-standalone migrate",
    "docker:build": "docker build -f packages/standalone/Dockerfile . -t cloud-local",
    "docker:dev": "docker compose up -d",
    "docker:update": "docker compose pull",
    "check:skills": "bun run scripts/check-skills.ts",
    "check:boundaries": "bun run scripts/check-boundaries.ts",
    "check:cycles": "CHECK_APPS_CYCLES=1 bun run scripts/check-cycles.ts",
    "check:cycles:core": "bun run scripts/check-cycles.ts",
    "check:service-api-contracts": "bun run scripts/check-service-api-contracts.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.2.3",
    "typescript": "^5.9.3"
  }
}

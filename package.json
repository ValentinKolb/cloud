{
  "name": "@valentinkolb/cloud-workspace",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/accounts",
    "packages/api-docs",
    "packages/assistant",
    "packages/cloud",
    "packages/contacts",
    "packages/core",
    "packages/cloud-cli",
    "packages/dashboard",
    "packages/faq",
    "packages/files",
    "packages/gateway",
    "packages/gateway-ops",
    "packages/grids",
    "packages/ipa-hosts",
    "packages/mail",
    "packages/notebooks",
    "packages/oauth",
    "packages/pulse",
    "packages/proxy-auth",
    "packages/quotes",
    "packages/spaces",
    "packages/tools",
    "packages/ui-lab",
    "packages/venue",
    "packages/weather"
  ],
  "exports": {
    ".": "./packages/cloud/src/index.ts",
    "./ui": "./packages/cloud/src/ui/index.ts",
    "./ui/styles.css": "./packages/cloud/src/styles/global.css",
    "./desktop": "./packages/cloud/src/desktop/index.ts",
    "./desktop/solid": "./packages/cloud/src/desktop/solid.tsx",
    "./server": "./packages/cloud/src/server/index.ts",
    "./browser": "./packages/cloud/src/server/api-client.ts",
    "./cli": "./packages/cloud/src/cli/index.ts",
    "./cli/access": "./packages/cloud/src/cli/access.ts",
    "./shared": "./packages/cloud/src/shared/index.ts",
    "./services": "./packages/cloud/src/services/index.ts",
    "./services/*": "./packages/cloud/src/services/*",
    "./ai": "./packages/cloud/src/ai/index.ts",
    "./ai/browser": "./packages/cloud/src/ai/browser.ts",
    "./ai/solid": "./packages/cloud/src/ai/solid.ts",
    "./ssr": "./packages/cloud/src/ssr/index.ts",
    "./ssr/islands": "./packages/cloud/src/ssr/islands/index.ts",
    "./config": "./packages/cloud/src/config/index.ts",
    "./config/*": "./packages/cloud/src/config/*",
    "./contracts": "./packages/cloud/src/contracts/index.ts",
    "./api": "./packages/cloud/src/api/index.ts",
    "./clients/core": "./packages/cloud/src/clients/core.ts",
    "./styles/global.css": "./packages/cloud/src/styles/global.css"
  },
  "scripts": {
    "infra": "docker compose -f compose.yml up -d",
    "infra:down": "docker compose -f compose.yml down",
    "dev": "docker compose -f compose.dev.yml up --build",
    "dev:full": "docker compose -f compose.dev.yml --profile extra up --build",
    "dev:down": "docker compose -f compose.dev.yml --profile extra down --remove-orphans",
    "dev:rebuild:all": "docker compose -f compose.dev.yml --profile extra up --build -d",
    "dev:start": "bun run scripts/dev-start.ts",
    "dev:stop": "bun run scripts/dev-stop.ts",
    "dev:rebuild": "bun run scripts/dev-rebuild.ts",
    "dev:logs": "bun run scripts/dev-logs.ts",
    "dev:status": "bun run scripts/dev-status.ts",
    "dev:help": "bun run scripts/dev-help.ts",
    "format": "bun run scripts/run-biome.ts format",
    "format:check": "bun run scripts/run-biome.ts format:check",
    "lint": "bun run scripts/run-biome.ts lint",
    "lint:fix": "bun run scripts/run-biome.ts lint:fix",
    "check:biome": "bun run scripts/run-biome.ts check:biome",
    "skills:install": "./scripts/symlink-skills.sh",
    "typecheck": "bun run check:skills && bun run check:boundaries && bun run check:cycles && bun run check:service-api-contracts && bun run check:ui-lab && bun run check:biome && bun run scripts/run-package-typechecks.ts",
    "check": "bun run typecheck",
    "check:skills": "bun run scripts/check-skills.ts",
    "check:boundaries": "bun run scripts/check-boundaries.ts",
    "check:cycles": "CHECK_APPS_CYCLES=1 bun run scripts/check-cycles.ts",
    "check:cycles:core": "bun run scripts/check-cycles.ts",
    "check:service-api-contracts": "bun run scripts/check-service-api-contracts.ts",
    "check:ui-lab": "bun run scripts/check-ui-lab-coverage.ts"
  },
  "dependencies": {
    "@valentinkolb/stdlib": "0.12.0",
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.2.3",
    "typescript": "^5.9.3"
  },
  "license": "AGPL-3.0-or-later"
}
